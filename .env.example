# Frontend (Vite)
# Public URL for your deployed backend API (without trailing slash).
# Example local value: http://localhost:8000
VITE_API_BASE_URL=

# Backend (FastAPI + MySQL)
# Use either MYSQL_URL/DATABASE_URL OR the discrete MYSQL_* variables below.
MYSQL_URL=
DATABASE_URL=

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root1234
MYSQL_DATABASE=medidiag

# Recommended true for local MySQL, false for managed cloud MySQL.
MYSQL_AUTO_CREATE_DB=true

# Recommended true for local MySQL, false for managed cloud MySQL.
MYSQL_SSL_DISABLED=true
# MYSQL_SSL_CA=/path/to/ca.pem

# Comma-separated frontend origins allowed to call the backend.
# Example production value: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

