# ── Frontend (Vite / Vercel) ─────────────────────────────────────────
# Full URL of your Render backend. Set this in Vercel's dashboard.
# Example: https://medidiag-backend.onrender.com
VITE_API_BASE_URL=

# ── Backend (FastAPI + PostgreSQL) ───────────────────────────────────
# Render provides DATABASE_URL automatically — no need to set it manually.
# For local development, fill in the values below.

# Option A — single connection string (recommended for local + cloud)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/medidiag

# Option B — individual params (used as fallback if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=medidiag

# ── CORS ─────────────────────────────────────────────────────────────
# Local dev (comma-separated):
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Production — set this in the Render dashboard after deploying Vercel:
# CORS_ORIGINS=https://your-app.vercel.app
